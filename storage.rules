rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 🎥 Videos — authenticated users can upload to their own folder
    match /videos/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && fileName.matches(request.auth.uid + '_.*')
        && request.resource.size < 200 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }

    // 📸 Images — authenticated users can upload to their own folder
    match /images/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && fileName.matches(request.auth.uid + '_.*')
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // 🗂️ Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // 🎥 Videos — authenticated users can upload to their own folder
    match /videos/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && fileName.matches(request.auth.uid + '_.*')
        && request.resource.size < 200 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
    }

    // 📸 Images — authenticated users can upload to their own folder
    match /images/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && fileName.matches(request.auth.uid + '_.*')
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    // 📖 Stories — users upload to their own subfolder, admins upload to stories/admin/
    match /stories/{userId}/{fileName} {
      allow read: if request.auth != null;

      // Regular users: can only write to their own uid subfolder
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 50 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('video/.*')
        );

      // Admins: can write to stories/admin/ subfolder
      allow write: if request.auth != null
        && request.auth.token.admin == true
        && userId == 'admin'
        && request.resource.size < 50 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('video/.*')
        );

      allow delete: if request.auth != null
        && (request.auth.uid == userId || request.auth.token.admin == true);
    }

    // 🎬 Reels (post videos) — each user uploads to their own subfolder
    match /reels/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 200 * 1024 * 1024
        && request.resource.contentType.matches('video/.*');
      allow delete: if request.auth != null
        && request.auth.uid == userId;
    }

    // 🖼️ Profile pictures
    match /profilePics/{userId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
        && request.auth.uid == userId;
    }

    // 🗂️ Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

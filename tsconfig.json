{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,

    // 🔥 Required for modern TS + Expo
    "moduleResolution": "bundler",

    // ✅ Enable @/ path
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },

    // 🔕 Silence TS deprecation warnings (important)
    "ignoreDeprecations": "6.0",

    // ✅ Recommended settings
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },

  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}
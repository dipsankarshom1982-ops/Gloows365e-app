{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,

    // 🔥 Required for Expo + TS
    "moduleResolution": "bundler",

    // ✅ Path alias (@/)
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    },

    // 🔕 Silence TS warnings
    "ignoreDeprecations": "6.0",

    // ✅ Recommended settings
    "jsx": "react-jsx",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },

  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ],

  "exclude": [
    "node_modules"
  ]
}
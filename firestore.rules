rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🔒 STUDENTS PROFILE
    match /students/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.admin == true);
      allow create, update, delete: if request.auth.uid == userId;
    }

    // 🔥 POSTS (Timeline + Reels + SkillBattle)
    match /posts/{postId} {

      // ✅ Allow logged-in users to read posts (needed for timeline)
      allow read: if request.auth != null;

      // ✅ Create post (strict validation)
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      // ✅ Admin can update any field (status, rejectionReason, reviewedBy, etc.)
      // ✅ Owner can edit their post
      // ✅ Any signed-in user can update engagement counters only
      allow update: if request.auth != null
        && (
          request.auth.token.admin == true
          || (
            request.resource.data.userId == resource.data.userId
            && (
              request.auth.uid == resource.data.userId
              || request.resource.data.diff(resource.data).changedKeys().hasOnly([
                'views', 'likes', 'comments', 'watchTime', 'shares'
              ])
            )
          )
        );

      // ✅ Owner can delete; admin can delete
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.userId || request.auth.token.admin == true);

      // ❤️ Likes Subcollection
      match /likes/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth.uid == userId;
      }

      // 💬 Comments Subcollection
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if request.auth != null
          && request.auth.uid == resource.data.userId;
      }
    }

    // 👤 USERS — profile + V-Coins balance fields
    match /users/{userId} {
      allow read:   if request.auth.uid == userId;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;
      allow delete: if false;

      // 💰 V-Coins transaction log (immutable after create)
      match /vCoinTransactions/{txId} {
        allow read:   if request.auth.uid == userId;
        allow create: if request.auth.uid == userId
          && request.resource.data.amount > 0
          && request.resource.data.amount <= 1500
          && request.resource.data.type in ["CREDIT", "DEBIT"]
          && request.resource.data.status in ["SUCCESS", "PENDING"];
        allow update, delete: if false;
      }

      // 🔒 V-Coins activity locks (duplicate / daily-limit prevention)
      match /vCoinActivityLocks/{lockId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // 📋 V-COIN RULES (admin writes, authenticated reads)
    match /vCoinRules/{ruleId} {
      allow read:  if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // 🤖 AI CHATS
    match /aiChats/{userId} {
      allow read, write: if request.auth.uid == userId;
      match /messages/{messageId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // 🔖 BOOKMARKS
    match /bookmarks/{userId} {
      allow read, write: if request.auth.uid == userId;
      match /saved/{bookmarkId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // 🏆 SKILLBOARD (Leaderboard)
    match /skillboard/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 🎯 BANNERS (Admin only)
    match /banners/{bannerId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // 🏁 CONTESTS + subcollections
    match /contests/{contestId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth.token.admin == true;
      allow update: if request.auth.token.admin == true
        || (
          request.auth != null
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['joinedCount', 'updatedAt'])
          && request.resource.data.joinedCount == resource.data.joinedCount + 1
          && request.resource.data.joinedCount <= resource.data.totalSpots
        );
      match /participant/{userId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.userId == request.auth.uid;
        allow update: if request.auth != null && request.auth.uid == userId;
      }
    }

    // 🧠 QUIZZES + questions subcollection
    match /quizzes/{quizId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
      match /questions/{questionId} {
        allow read: if request.auth != null;
        allow write: if request.auth.token.admin == true;
      }
    }

    // 🔍 Collection group rule for participant
    match /{path=**}/participant/{userId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ✍️ ATTEMPTS
    match /attempts/{attemptId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.userId || request.auth.token.admin == true);
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.contestId is string
        && request.resource.data.answers is list;
      allow update, delete: if request.auth.token.admin == true;
    }

    // 📖 STORIES
    match /stories/{storyId} {
      allow read: if request.auth != null
        && (resource.data.status == "approved" || request.auth.uid == resource.data.userId);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.userId || request.auth.token.admin == true);
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // ⚔️ SKILL BATTLES — admin full control, authenticated read
    match /skillBattles/{battleId} {
      allow read: if request.auth != null;
      allow create: if request.auth.token.admin == true;
      allow update: if request.auth.token.admin == true
        || (
          request.auth != null
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'participants', 'participantCount', 'joinedCount'
          ])
        );
      allow delete: if request.auth.token.admin == true;
    }

    // 🤝 PARTNERS
    match /partners/{partnerId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // 🎮 LEARNFUN
    match /dailyFunLearnMissions/{missionId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }
    match /LearnFunGames/{gameId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }
    match /LearnFunBadges/{badgeId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }
    match /leaderboard/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /leaderboards/{tab}/{scope}/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /studentLearnFunProgress/{userId} {
      allow read, write: if request.auth.uid == userId;
      match /missions/{missionId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // 🔔 NOTIFICATIONS
    match /notifications/{userId} {
      allow read, write: if request.auth.uid == userId;
      match /items/{itemId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // 📺 SEEKHO VIDEOS
    match /seekhoVideos/{videoId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // 🎬 SHORT REELS
    match /short_reels/{reelId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // 🌐 KNOWLEDGE HUB VIDEOS
    match /knowledgeVideos/{videoId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // 📢 HOME ADS
    match /homeAds/{adId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // 📢 UNIFIED ADS
    match /ads/{adId} {
      allow read: if request.auth != null
        && resource.data.isActive == true
        && resource.data.isApproved == true;
      allow write: if request.auth.token.admin == true;
    }

    // 📊 AD ANALYTICS
    match /adAnalytics/{adId} {
      allow read: if request.auth.token.admin == true;
      allow write: if false;
      match /events/{eventId} {
        allow read:   if request.auth.token.admin == true;
        allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /adFrequency/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    match /shikshaStars/{starId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    match /dashboard/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // 🎓 AI GURU LESSONS
    match /aiGuruLessons/{lessonId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "generating";
      allow update, delete: if false;
      match /quizAttempts/{attemptId} {
        allow read: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/aiGuruLessons/$(lessonId)).data.uid;
        allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /aiGuruUsage/{uid} {
      allow read: if request.auth.uid == uid;
      allow write: if false;
      match /daily/{date} {
        allow read: if request.auth.uid == uid;
        allow write: if false;
      }
    }

    match /subscriptions/{uid} {
      allow read: if request.auth.uid == uid || request.auth.token.admin == true;
      allow write: if false;
    }

    // 📚 SEEKHO MODULE
    match /seekho_courses/{courseId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }
    match /seekho_lessons/{lessonId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }
    match /seekho_practice/{questionId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }
    match /seekho_progress/{progressId} {
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    match /seekho_subscriptions/{userId} {
      allow read: if request.auth.uid == userId || request.auth.token.admin == true;
      allow write: if false;
    }
    match /seekho_revision_queue/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // 🧭 DISCOVER AI MODULE
    match /discoverUsage/{uid} {
      allow read: if request.auth.uid == uid;
      allow write: if false;
      match /daily/{date} {
        allow read: if request.auth.uid == uid;
        allow write: if false;
      }
    }
    match /discoverHistory/{uid} {
      allow read, write: if request.auth.uid == uid;
    }
    match /discoverCache/{hash} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ⚙️ APP CONFIG
    match /appModules/{moduleId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }
    match /subscriptionPlans/{planId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }
    match /appConfig/{configId} {
      allow read:  if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }
    match /featureFlags/{flagId} {
      allow read:  if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // 🎟️ COUPONS
    match /coupons/{id} {
      allow read, write: if request.auth.token.admin == true;
    }

    // 🎁 REFERRALS — Cloud Functions write only; users can read their own
    match /referrals/{referralId} {
      allow read: if request.auth != null
        && (resource.data.referrerId == request.auth.uid
            || resource.data.refereeId == request.auth.uid
            || request.auth.token.admin == true);
      allow write: if false;
    }

    // 👑 ADMINS
    match /admins/{uid} {
      allow read:  if request.auth.token.admin == true;
      allow write: if request.auth.token.superAdmin == true;
    }

    // 🔒 DEFAULT DENY
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

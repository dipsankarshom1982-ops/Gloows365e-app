rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🔒 STUDENTS PROFILE
    match /students/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || request.auth.token.admin == true);
      allow create, update, delete: if request.auth.uid == userId;
    }

    // 🔥 POSTS
    match /posts/{postId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
        && (
          request.auth.token.admin == true
          || (
            request.resource.data.userId == resource.data.userId
            && (
              request.auth.uid == resource.data.userId
              || request.resource.data.diff(resource.data).changedKeys().hasOnly([
                'views', 'likes', 'comments', 'watchTime', 'shares'
              ])
            )
          )
        );
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.userId || request.auth.token.admin == true);

      match /likes/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth.uid == userId;
      }
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if request.auth != null
          && request.auth.uid == resource.data.userId;
      }
    }

    // 👤 USERS — all profile types (student, restartEducation, parent)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId
        && !request.resource.data.diff(resource.data).changedKeys().hasAny([
          'vCoins', 'vCoinsLifetimeEarned', 'vCoinsLifetimeSpent',
          'vCoinsYear_2024','vCoinsYear_2025','vCoinsYear_2026','vCoinsYear_2027','vCoinsYear_2028',
          'vCoinsHistory_2024','vCoinsHistory_2025','vCoinsHistory_2026','vCoinsHistory_2027','vCoinsHistory_2028'
        ]);
      allow update: if request.auth.token.admin == true;
      allow delete: if false;

      // ✅ FIX: Clients can no longer write transaction docs directly.
      // All vCoinTransactions are written only by Cloud Functions (Admin SDK).
      match /vCoinTransactions/{txId} {
        allow read:                   if request.auth.uid == userId;
        allow create, update, delete: if false;
      }
      match /vCoinActivityLocks/{lockId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // 📋 V-COIN RULES
    match /vCoinRules/{ruleId} {
      allow read:  if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // 🤖 AI CHATS (student AI Guru)
    match /aiChats/{userId} {
      allow read, write: if request.auth.uid == userId;
      match /messages/{messageId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // 📓 AI NOTEBOOK — saved Q&A entries
    match /aiNotebook/{userId} {
      allow read, write: if request.auth.uid == userId;
      match /entries/{entryId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // 🎓 RESTART EDUCATION CHATS (separate from AI Guru)
    match /restartEducationChats/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // 📋 EDUCATION LEADS
    match /educationLeads/{leadId} {
      // Users can create their own leads
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      // Users can read their own leads
      allow read: if request.auth != null
        && (resource.data.userId == request.auth.uid || request.auth.token.admin == true);
      // Only admin can update (status, partner, notes)
      allow update: if request.auth.token.admin == true;
      allow delete: if false;
    }

    // 🎓 EDUCATION PATHWAYS (admin writes, all authenticated read)
    match /educationPathways/{pathwayId} {
      allow read:  if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // 🔖 BOOKMARKS
    match /bookmarks/{userId} {
      allow read, write: if request.auth.uid == userId;
      match /saved/{bookmarkId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // 🏆 SKILLBOARD
    match /skillboard/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 🎯 BANNERS
    match /banners/{bannerId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // 🏁 CONTESTS
    match /contests/{contestId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth.token.admin == true;
      allow update: if request.auth.token.admin == true
        || (
          request.auth != null
          && request.resource.data.diff(resource.data).changedKeys().hasOnly(['joinedCount', 'updatedAt'])
          && request.resource.data.joinedCount == resource.data.joinedCount + 1
          && request.resource.data.joinedCount <= resource.data.totalSpots
        );
      match /participant/{userId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.userId == request.auth.uid;
        allow update: if request.auth != null && request.auth.uid == userId;
      }
    }

    // 🧠 QUIZZES
    match /quizzes/{quizId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
      match /questions/{questionId} {
        allow read: if request.auth != null;
        allow write: if request.auth.token.admin == true;
      }
    }

    match /{path=**}/participant/{userId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // ✍️ ATTEMPTS
    match /attempts/{attemptId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.userId || request.auth.token.admin == true);
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.contestId is string
        && request.resource.data.answers is list;
      allow update, delete: if request.auth.token.admin == true;
    }

    // 📖 STORIES
    match /stories/{storyId} {
      allow read: if request.auth != null
        && (resource.data.status == "approved" || request.auth.uid == resource.data.userId || request.auth.token.admin == true);
      allow create: if request.auth != null
        && (
          request.resource.data.userId == request.auth.uid
          || request.auth.token.admin == true
        );
      allow update: if request.auth != null
        && (request.auth.uid == resource.data.userId || request.auth.token.admin == true);
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.userId || request.auth.token.admin == true);
    }

    // ⚔️ SKILL BATTLES
    match /skillBattles/{battleId} {
      allow read: if request.auth != null;
      allow create: if request.auth.token.admin == true;
      allow update: if request.auth.token.admin == true
        || (
          request.auth != null
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'participants', 'participantCount', 'joinedCount'
          ])
        );
      allow delete: if request.auth.token.admin == true;
    }

    // 🤝 PARTNERS
    match /partners/{partnerId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // 🎮 LEARNFUN
    match /dailyFunLearnMissions/{missionId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }
    match /LearnFunGames/{gameId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }
    match /LearnFunBadges/{badgeId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }
    match /leaderboard/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    match /leaderboards/{tab}/{scope}/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }
    match /studentLearnFunProgress/{userId} {
      allow read, write: if request.auth.uid == userId;
      match /missions/{missionId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // 🔔 NOTIFICATIONS
    match /notifications/{userId} {
      allow read, write: if request.auth.uid == userId;
      match /items/{itemId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // 📺 VIDEOS
    match /seekhoVideos/{videoId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }
    match /short_reels/{reelId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }
    match /knowledgeVideos/{videoId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // 📢 ADS
    match /homeAds/{adId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }
    match /ads/{adId} {
      allow read: if request.auth != null
        && resource.data.isActive == true
        && resource.data.isApproved == true;
      allow write: if request.auth.token.admin == true;
    }
    match /adAnalytics/{adId} {
      allow read: if request.auth.token.admin == true;
      allow write: if false;
      match /events/{eventId} {
        allow read:   if request.auth.token.admin == true;
        allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
        allow update, delete: if false;
      }
    }
    match /adFrequency/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    match /shikshaStars/{starId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }
    match /dashboard/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // 🎓 AI GURU LESSONS
    match /aiGuruLessons/{lessonId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "generating";
      allow update, delete: if false;
      match /quizAttempts/{attemptId} {
        allow read: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/aiGuruLessons/$(lessonId)).data.uid;
        allow create: if request.auth != null && request.resource.data.uid == request.auth.uid;
        allow update, delete: if false;
      }
    }
    match /aiGuruUsage/{uid} {
      allow read: if request.auth.uid == uid;
      allow write: if false;
      match /daily/{date} {
        allow read: if request.auth.uid == uid;
        allow write: if false;
      }
    }

    match /subscriptions/{uid} {
      allow read: if request.auth.uid == uid || request.auth.token.admin == true;
      allow write: if false;
    }

    // 📚 SEEKHO MODULE
    match /seekho_courses/{courseId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }
    match /seekho_lessons/{lessonId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }
    match /seekho_practice/{questionId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }
    match /seekho_progress/{progressId} {
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }
    match /seekho_subscriptions/{userId} {
      allow read: if request.auth.uid == userId || request.auth.token.admin == true;
      allow write: if false;
    }
    match /seekho_revision_queue/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false;
    }

    // 🧭 DISCOVER AI
    match /discoverUsage/{uid} {
      allow read: if request.auth.uid == uid;
      allow write: if false;
      match /daily/{date} {
        allow read: if request.auth.uid == uid;
        allow write: if false;
      }
    }
    match /discoverHistory/{uid} {
      allow read, write: if request.auth.uid == uid;
    }
    match /discoverCache/{hash} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ⚙️ APP CONFIG
    match /appModules/{moduleId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }
    match /subscriptionPlans/{planId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }
    match /appConfig/{configId} {
      allow read:  if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }
    match /featureFlags/{flagId} {
      allow read:  if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // 🎟️ COUPONS
    match /coupons/{id} {
      allow read, write: if request.auth.token.admin == true;
    }

    // 🎁 REFERRALS
    match /referrals/{referralId} {
      allow read: if request.auth != null
        && (resource.data.referrerId == request.auth.uid
            || resource.data.refereeId == request.auth.uid
            || request.auth.token.admin == true);
      allow write: if false;
    }

    // 👑 ADMINS
    match /admins/{uid} {
      allow read:  if request.auth.token.admin == true;
      allow write: if request.auth.token.superAdmin == true;
    }

    // 🐛 CRASH REPORTS — written by app, read by admin only
    match /crashReports/{reportId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth.token.admin == true;
      allow delete: if false;
    }
    match /affiliateProducts/{productId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // 📸 PHOTOSOLVE USAGE
    match /photoSolveUsage/{uid} {
      allow read: if request.auth.uid == uid;
      allow write: if false;
      match /daily/{date} {
        allow read: if request.auth.uid == uid;
        allow write: if false;
      }
    }

    // 🎯 EXAM SIMULATOR
    match /examSimulator/{uid} {
      allow read: if request.auth.uid == uid || request.auth.token.admin == true;
      allow write: if false;
      match /exams/{examId} {
        allow read: if request.auth.uid == uid;
        allow write: if false;
      }
    }

    // 🎙️ VOICE TUTOR USAGE
    match /voiceTutorUsage/{uid} {
      allow read: if request.auth.uid == uid;
      allow write: if false;
      match /daily/{date} {
        allow read: if request.auth.uid == uid;
        allow write: if false;
      }
    }
  }
}

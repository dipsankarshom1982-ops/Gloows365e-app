rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🔒 STUDENTS PROFILE
    match /students/{userId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth.uid == userId;
    }

    // 🔥 POSTS (Timeline + Reels + SkillBattle)
    match /posts/{postId} {
      
      // ✅ Allow logged-in users to read posts (needed for timeline)
      allow read: if request.auth != null;

      // ✅ Create post (strict validation)
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      // ✅ Owner can edit their post, and any signed-in user can update engagement counters only
      allow update: if request.auth != null
        && request.resource.data.userId == resource.data.userId
        && (
          request.auth.uid == resource.data.userId
          || request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'views',
            'likes',
            'comments',
            'watchTime',
            'shares'
          ])
        );

      // ✅ Only owner can delete
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.userId;

      // ❤️ Likes Subcollection
      match /likes/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth.uid == userId;
      }

      // 💬 Comments Subcollection
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if request.auth != null
          && request.auth.uid == resource.data.userId;
      }
    }

    // 👤 USERS (legacy or optional)
    match /users/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // 🤖 AI CHATS
    match /aiChats/{userId} {
      allow read, write: if request.auth.uid == userId;

      match /messages/{messageId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // 🔖 BOOKMARKS
    match /bookmarks/{userId} {
      allow read, write: if request.auth.uid == userId;

      match /saved/{bookmarkId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // 🏆 SKILLBOARD (Leaderboard)
    match /skillboard/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 🎯 BANNERS (Admin only)
    match /banners/{bannerId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // 🏁 CONTESTS
    match /contests/{contestId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth.token.admin == true;
      allow update: if request.auth.token.admin == true
        || (
          request.auth != null
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'joinedCount',
            'updatedAt'
          ])
          && request.resource.data.joinedCount == resource.data.joinedCount + 1
          && request.resource.data.joinedCount <= resource.data.totalSpots
        );
    }

    // 📍 CONTEST PARTICIPANTS
    match /contestParticipants/{docId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.contestId is string
        && request.resource.data.score == 0
        && request.resource.data.rank == null
        && request.resource.data.status == 'joined';

      allow update, delete: if request.auth.token.admin == true;
    }

    // 🧠 QUIZZES
    match /quizzes/{quizId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // ✍️ ATTEMPTS
    match /attempts/{attemptId} {
      allow read: if request.auth != null
        && (
          request.auth.uid == resource.data.userId
          || request.auth.token.admin == true
        );

      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.contestId is string
        && request.resource.data.quizId is string
        && request.resource.data.answers is list;

      allow update, delete: if request.auth.token.admin == true;
    }

    // 🔒 DEFAULT DENY
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
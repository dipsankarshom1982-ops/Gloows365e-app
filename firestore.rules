rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 🔒 STUDENTS PROFILE
    match /students/{userId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth.uid == userId;
    }

    // 🔥 POSTS (Timeline + Reels + SkillBattle)
    match /posts/{postId} {
      
      // ✅ Allow logged-in users to read posts (needed for timeline)
      allow read: if request.auth != null;

      // ✅ Create post (strict validation)
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      // ✅ Owner can edit their post, and any signed-in user can update engagement counters only
      allow update: if request.auth != null
        && request.resource.data.userId == resource.data.userId
        && (
          request.auth.uid == resource.data.userId
          || request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'views',
            'likes',
            'comments',
            'watchTime',
            'shares'
          ])
        );

      // ✅ Only owner can delete
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.userId;

      // ❤️ Likes Subcollection
      match /likes/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth.uid == userId;
      }

      // 💬 Comments Subcollection
      match /comments/{commentId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if request.auth != null
          && request.auth.uid == resource.data.userId;
      }
    }

    // 👤 USERS — profile + V-Coins balance fields
    match /users/{userId} {
      allow read:   if request.auth.uid == userId;
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId; // ⚡ Tighten to Cloud Function only after migration
      allow delete: if false;

      // 💰 V-Coins transaction log (immutable after create)
      match /vCoinTransactions/{txId} {
        allow read:   if request.auth.uid == userId;
        allow create: if request.auth.uid == userId
          && request.resource.data.amount > 0
          && request.resource.data.amount <= 1500
          && request.resource.data.type in ["CREDIT", "DEBIT"]
          && request.resource.data.status in ["SUCCESS", "PENDING"];
        allow update, delete: if false; // reversal = new REVERSED doc
      }

      // 🔒 V-Coins activity locks (duplicate / daily-limit prevention)
      match /vCoinActivityLocks/{lockId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // 📋 V-COIN RULES (admin writes, authenticated reads)
    match /vCoinRules/{ruleId} {
      allow read:  if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // 🤖 AI CHATS
    match /aiChats/{userId} {
      allow read, write: if request.auth.uid == userId;

      match /messages/{messageId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // 🔖 BOOKMARKS
    match /bookmarks/{userId} {
      allow read, write: if request.auth.uid == userId;

      match /saved/{bookmarkId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // 🏆 SKILLBOARD (Leaderboard)
    match /skillboard/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 🎯 BANNERS (Admin only)
    match /banners/{bannerId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // 🏁 CONTESTS + subcollections
    match /contests/{contestId} {
      allow read: if request.auth != null;
      allow create, delete: if request.auth.token.admin == true;
      allow update: if request.auth.token.admin == true
        || (
          request.auth != null
          && request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'joinedCount',
            'updatedAt'
          ])
          && request.resource.data.joinedCount == resource.data.joinedCount + 1
          && request.resource.data.joinedCount <= resource.data.totalSpots
        );

      // 📍 PARTICIPANT subcollection — document ID is the userId
      match /participant/{userId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.auth.uid == userId
          && request.resource.data.userId == request.auth.uid;
        allow update: if request.auth != null
          && request.auth.uid == userId;
      }
    }

    // 🧠 QUIZZES + questions subcollection
    match /quizzes/{quizId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;

      // ❓ QUESTIONS subcollection
      match /questions/{questionId} {
        allow read: if request.auth != null;
        allow write: if request.auth.token.admin == true;
      }
    }

    // 🔍 Collection group rule for participant (needed for collectionGroup query in useUserContests)
    match /{path=**}/participant/{userId} {
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // ✍️ ATTEMPTS
    match /attempts/{attemptId} {
      allow read: if request.auth != null
        && (
          request.auth.uid == resource.data.userId
          || request.auth.token.admin == true
        );

      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.contestId is string
        && request.resource.data.quizId is string
        && request.resource.data.answers is list;

      allow update, delete: if request.auth.token.admin == true;
    }

    // 📖 STORIES
    match /stories/{storyId} {
      // Approved stories visible to all authenticated users.
      // Pending / rejected stories visible only to the owner.
      allow read: if request.auth != null
        && (
          resource.data.status == "approved"
          || request.auth.uid == resource.data.userId
        );
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null
        && (
          request.auth.uid == resource.data.userId
          || request.auth.token.admin == true
        );
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
    }

    // ⚔️ SKILL BATTLES
    match /skillBattles/{battleId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if request.auth != null
        && (
          request.auth.uid == resource.data.createdBy
          || request.resource.data.diff(resource.data).changedKeys().hasOnly([
            'participants', 'joinedCount', 'status', 'winnerId', 'scores'
          ])
        );
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.createdBy;
    }

    // 🤝 PARTNERS (linked story sponsors — admin writes, all authenticated users read)
    match /partners/{partnerId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // 🎮 LEARNFUN — Daily missions (public read for authenticated users)
    match /dailyFunLearnMissions/{missionId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // 🎮 LEARNFUN — Game catalog (public read for authenticated users)
    match /LearnFunGames/{gameId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // 🎮 LEARNFUN — Badge catalog (public read for authenticated users)
    match /LearnFunBadges/{badgeId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // 🏆 LEARNFUN — Pan India Leaderboard (score only, queryable by all authenticated users)
    match /leaderboard/{uid} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // 🏆 SKILL LEADERBOARDS — nested collection leaderboards/{tab}/country/{uid}
    match /leaderboards/{tab}/{scope}/{uid} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 🎮 LEARNFUN — Student progress (own data only)
    match /studentLearnFunProgress/{userId} {
      allow read, write: if request.auth.uid == userId;

      match /missions/{missionId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // 🔔 NOTIFICATIONS
    match /notifications/{userId} {
      allow read, write: if request.auth.uid == userId;

      match /items/{itemId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    // 📺 SEEKHO VIDEOS (admin writes, all authenticated users read)
    match /seekhoVideos/{videoId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // 🌐 KNOWLEDGE HUB VIDEOS (admin writes, all authenticated users read)
    match /knowledgeVideos/{videoId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // 📢 HOME ADS (admin writes, all authenticated users read)
    match /homeAds/{adId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // ⭐ SHIKSHA STARS (admin writes, all authenticated users read)
    match /shikshaStars/{starId} {
      allow read: if request.auth != null;
      allow write: if request.auth.token.admin == true;
    }

    // 📊 DASHBOARD (own data only — future use)
    match /dashboard/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // 🎓 AI GURU LESSONS (Cloud Functions write, owner reads)
    match /aiGuruLessons/{lessonId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.uid;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.status == "generating";
      allow update, delete: if false; // Cloud Functions only

      match /quizAttempts/{attemptId} {
        allow read: if request.auth != null
          && request.auth.uid == get(/databases/$(database)/documents/aiGuruLessons/$(lessonId)).data.uid;
        allow create: if request.auth != null
          && request.resource.data.uid == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // 📈 AI GURU USAGE (Cloud Functions write, owner reads)
    match /aiGuruUsage/{uid} {
      allow read: if request.auth.uid == uid;
      allow write: if false; // Cloud Functions only

      match /daily/{date} {
        allow read: if request.auth.uid == uid;
        allow write: if false;
      }
    }

    // 💎 SUBSCRIPTIONS (Cloud Functions / admin write, owner reads)
    match /subscriptions/{uid} {
      allow read: if request.auth.uid == uid;
      allow write: if false; // Cloud Functions / admin only
    }

    // 🔒 DEFAULT DENY
    match /{document=**} {
      allow read, write: if false;
    }
  }
}